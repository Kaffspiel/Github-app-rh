                            "value": "Bearer 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"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"messages\": [\n    { \"role\": \"system\", \"content\": \"{{ $json.prompt }}. Responda apenas JSON válido: {\\\"title\\\":\\\"\\\", \\\"assignee_id\\\":\\\"\\\", \\\"priority\\\":\\\"média\\\", \\\"due_date\\\":\\\"YYYY-MM-DD\\\"}\" },\n    { \"role\": \"user\", \"content\": \"{{ $json.userMessage }}\" }\n  ],\n  \"response_format\": { \"type\": \"json_object\" }\n}",
