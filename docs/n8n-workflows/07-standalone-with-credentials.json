        {
            "parameters": {
                "jsCode": "/**\n * Prepara o prompt e consolida os dados para a OpenAI.\n * Isso evita erros de [undefined] no n8n.\n */\nconst employees = $node[\"Buscar Equipe\"].json;\nconst meta = $node[\"Extrair Dados\"].json;\nconst gestor = $node[\"Buscar Gestor\"].json[0];\n\nconst employeeList = Array.isArray(employees) \n  ? employees.map(e => `${e.name} (ID: ${e.id})`).join(', ') \n  : '';\n\nreturn {\n  prompt: `Extraia a tarefa da mensagem. Funcionários disponíveis: ${employeeList}.`,\n  userMessage: meta.text,\n  company_id: gestor.company_id,\n  gestor_id: gestor.id\n};"
            },
            "id": "prepare-prompt-node",
            "name": "Preparar Prompt",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
