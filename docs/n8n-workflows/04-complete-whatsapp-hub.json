{
    "name": "OpsControl - Hub Central WhatsApp (Áudio + Texto)",
    "nodes": [
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "opscontrol-central-hub",
                "responseMode": "lastNode",
                "options": {}
            },
            "id": "webhook-evolution",
            "name": "Webhook Evolution API",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 2,
            "position": [
                100,
                300
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "filter-upsert",
                            "leftValue": "={{ $json.event }}",
                            "rightValue": "messages.upsert",
                            "operator": {
                                "type": "string",
                                "operation": "equals"
                            }
                        },
                        {
                            "id": "filter-not-from-me",
                            "leftValue": "={{ $json.data?.key?.fromMe }}",
                            "rightValue": false,
                            "operator": {
                                "type": "boolean",
                                "operation": "equals"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "id": "filter-incoming",
            "name": "Filtrar Recebidas",
            "type": "n8n-nodes-base.filter",
            "typeVersion": 2,
            "position": [
                300,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "// Extrai informações da mensagem\nconst data = $json.data || {};\nconst key = data.key || {};\nconst message = data.message || {};\n\nlet responseType = 'text';\nlet responseValue = '';\n\nif (message.buttonsResponseMessage) {\n  responseType = 'button';\n  responseValue = message.buttonsResponseMessage.selectedButtonId;\n} else if (message.audioMessage) {\n  responseType = 'audio_pending';\n} else if (message.conversation) {\n  responseValue = message.conversation;\n} else if (message.extendedTextMessage) {\n  responseValue = message.extendedTextMessage.text;\n}\n\nreturn {\n  messageId: key.id,\n  phone: key.remoteJid?.replace('@s.whatsapp.net', '').replace('@c.us', ''),\n  pushName: data.pushName,\n  responseType,\n  responseValue,\n  timestamp: new Date(data.messageTimestamp * 1000).toISOString(),\n  instance: $json.instance,\n  rawMessage: message\n};"
            },
            "id": "process-metadata",
            "name": "Processar Metadados",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                500,
                300
            ]
        },
        {
            "parameters": {
                "dataType": "string",
                "value1": "={{ $json.responseType }}",
                "rules": {
                    "rules": [
                        {
                            "value2": "audio_pending",
                            "output": 1
                        }
                    ]
                },
                "fallbackOutput": 0
            },
            "id": "switch-type",
            "name": "Tipo de Mensagem?",
            "type": "n8n-nodes-base.switch",
            "typeVersion": 3,
            "position": [
                700,
                300
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "={{ $env.EVOLUTION_URL }}/chat/getBase64FromMediaMessage/{{ $json.instance }}",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "apikey",
                            "value": "={{ $env.EVOLUTION_APIKEY }}"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={ \"message\": {{ JSON.stringify($json.rawMessage) }} }",
                "options": {
                    "response": {
                        "response": {
                            "fullResponse": true
                        }
                    }
                }
            },
            "id": "get-media",
            "name": "Download Áudio",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                900,
                450
            ]
        },
        {
            "parameters": {
                "resource": "audio",
                "operation": "transcribe",
                "fileContent": "={{ $json.body.base64 }}",
                "language": "pt",
                "options": {}
            },
            "id": "whisper-transcribe",
            "name": "OpenAI Whisper",
            "type": "n8n-nodes-base.openAi",
            "typeVersion": 1,
            "position": [
                1100,
                450
            ],
            "credentials": {
                "openAiApi": {
                    "id": "openai-cred-id",
                    "name": "OpenAI Account"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "// Normaliza o payload de áudio para conferir com o hub\nconst prevData = $node[\"Processar Metadados\"].json;\nreturn {\n  ...prevData,\n  responseType: 'audio_transcription',\n  responseValue: $json.text\n};"
            },
            "id": "format-audio-payload",
            "name": "Formatar Áudio",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1300,
                450
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "={{ $env.OPSCONTROL_URL }}/functions/v1/webhook-response",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Authorization",
                            "value": "Bearer {{ $env.OPSCONTROL_KEY }}"
                        },
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={{ JSON.stringify($json) }}",
                "options": {}
            },
            "id": "send-to-supabase",
            "name": "Enviar para Supabase",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1550,
                300
            ]
        }
    ],
    "connections": {
        "Webhook Evolution API": {
            "main": [
                [
                    {
                        "node": "Filtrar Recebidas",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Filtrar Recebidas": {
            "main": [
                [
                    {
                        "node": "Processar Metadados",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Processar Metadados": {
            "main": [
                [
                    {
                        "node": "Tipo de Mensagem?",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Tipo de Mensagem?": {
            "main": [
                [
                    {
                        "node": "Enviar para Supabase",
                        "type": "main",
                        "index": 0
                    }
                ],
                [
                    {
                        "node": "get-media",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "get-media": {
            "main": [
                [
                    {
                        "node": "whisper-transcribe",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "whisper-transcribe": {
            "main": [
                [
                    {
                        "node": "format-audio-payload",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "format-audio-payload": {
            "main": [
                [
                    {
                        "node": "Enviar para Supabase",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "settings": {
        "executionOrder": "v1"
    },
    "tags": [
        "opscontrol",
        "whatsapp",
        "audio-to-task"
    ]
}