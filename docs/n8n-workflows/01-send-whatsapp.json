          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"status\": \"sent\",\n  \"sent_at\": \"{{ new Date().toISOString() }}\",\n  \"whatsapp_message_id\": \"{{ $json.key?.id || $json.id || '' }}\",\n  \"whatsapp_status\": \"sent\"\n}",
        "options": {}
