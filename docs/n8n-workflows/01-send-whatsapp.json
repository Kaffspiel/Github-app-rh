        "jsonBody": "={\n  \"number\": \"{{ $json.body.number || $json.body.recipientPhone || '5511999999999' }}\",\n  \"title\": \"{{ $json.body.buttons?.title || $json.body.title || 'Título' }}\",\n  \"description\": \"{{ $json.body.buttons?.description || $json.body.message || '' }}\",\n  \"footer\": \"{{ $json.body.buttons?.footer || 'OpsControl' }}\",\n  \"buttons\": {{ JSON.stringify($json.body.buttons?.buttons || []) }},\n  \"metadata\": {{ JSON.stringify($json.body.metadata || {}) }}\n}",
        "options": {}
      },
